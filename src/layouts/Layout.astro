---
import '../styles/global.css';
import Icon from '../components/Icons.astro';
import CookieBanner from '../components/CookieBanner.astro';

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Eva Torres - Moda mujer, calzados y complementos en Arahal, Sevilla." />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Great+Vibes&family=Lato:wght@300;400;700&family=Playfair+Display:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet">
		<title>{title}</title>
	</head>
	<body class="flex flex-col min-h-screen">
		<slot />
        
        <a 
            href="https://wa.me/34651688937" 
            target="_blank" 
            class="fixed bottom-6 right-6 z-50 bg-[#25D366] hover:bg-[#20b858] text-white rounded-full shadow-2xl hover:scale-105 transition-transform duration-300 w-16 h-16 border-2 border-white flex items-center justify-center"
            aria-label="Contactar por WhatsApp"
        >
            <Icon name="whatsapp" class="w-9 h-9 fill-current" />
        </a>
		<CookieBanner />
	</body>
</html>