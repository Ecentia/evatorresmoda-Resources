---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

// Plantilla de productos (Puedes editar esto)
const products = [
    { name: "Vestido Floral Primavera", price: "29.95€", img: "https://images.unsplash.com/photo-1572804013309-59a88b7e92f1?q=80&w=800" },
    { name: "Blusa Elegante", price: "19.95€", img: "https://images.unsplash.com/photo-1551163943-3f6a29e39c73?q=80&w=800" },
    { name: "Pantalón Casual", price: "25.00€", img: "https://images.unsplash.com/photo-1541099649105-f69ad21f3246?q=80&w=800" },
    { name: "Chaqueta de Punto", price: "35.50€", img: "https://images.unsplash.com/photo-1574634534894-89d7576c8259?q=80&w=800" },
    { name: "Falda Midi", price: "22.95€", img: "https://images.unsplash.com/photo-1583496661160-fb5886a0aaaa?q=80&w=800" },
    { name: "Vestido de Noche", price: "45.00€", img: "https://images.unsplash.com/photo-1595777457583-95e059d581b8?q=80&w=800" },
];
---

<Layout title="Ropa de Mujer | Eva Torres">
    <Header />
    <main class="py-16 bg-gray-50">
        <div class="container mx-auto px-4">
            <h1 class="text-5xl font-brand text-center text-eva-green mb-4">Ropa de Mujer</h1>
            <p class="text-center text-gray-600 mb-12 max-w-2xl mx-auto">Descubre nuestra selección de prendas pensadas para la mujer actual. Comodidad y estilo en cada costura.</p>
            
            <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-8">
                {products.map((product) => (
                    <div class="bg-white p-4 shadow-sm hover:shadow-lg transition duration-300 rounded-sm group">
                        <div class="overflow-hidden mb-4 h-80 relative">
                            <img src={product.img} alt={product.name} class="w-full h-full object-cover group-hover:scale-105 transition duration-500" />
                            <div class="absolute bottom-0 right-0 bg-eva-green text-white px-3 py-1 font-bold">
                                {product.price}
                            </div>
                        </div>
                        <h3 class="text-lg font-serif font-bold text-gray-800">{product.name}</h3>
                        <p class="text-sm text-gray-500 mt-1">Disponible en tienda</p>
                    </div>
                ))}
            </div>
        </div>
    </main>
    <Footer />
</Layout>