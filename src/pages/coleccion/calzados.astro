---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const products = [
    { name: "Botín Tacón", price: "49.95€", img: "https://images.unsplash.com/photo-1543163521-1bf539c55dd2?q=80&w=800" },
    { name: "Zapatilla Urbana", price: "39.95€", img: "https://images.unsplash.com/photo-1560769629-975e13f0c470?q=80&w=800" },
    { name: "Sandalia Verano", price: "25.00€", img: "https://images.unsplash.com/photo-1562273138-f46be4ebdf33?q=80&w=800" },
    { name: "Zapato de Salón", price: "45.00€", img: "https://images.unsplash.com/photo-1518049362265-d5b2a6467637?q=80&w=800" },
    { name: "Bota Alta", price: "59.95€", img: "https://images.unsplash.com/photo-1608256246200-53e635b5b65f?q=80&w=800" },
    { name: "Mocasín Clásico", price: "35.00€", img: "https://images.unsplash.com/photo-1595950653106-6c9ebd614d3a?q=80&w=800" },
];
---

<Layout title="Calzados | Eva Torres">
    <Header />
    <main class="py-16 bg-gray-50">
        <div class="container mx-auto px-4">
            <h1 class="text-5xl font-brand text-center text-eva-green mb-4">Calzados</h1>
            <p class="text-center text-gray-600 mb-12 max-w-2xl mx-auto">Pisando fuerte con nuestra colección de zapatos. Calidad y confort para tus pies.</p>
            
            <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-8">
                {products.map((product) => (
                    <div class="bg-white p-4 shadow-sm hover:shadow-lg transition duration-300 rounded-sm group">
                        <div class="overflow-hidden mb-4 h-80 relative">
                            <img src={product.img} alt={product.name} class="w-full h-full object-cover group-hover:scale-105 transition duration-500" />
                            <div class="absolute bottom-0 right-0 bg-eva-green text-white px-3 py-1 font-bold">
                                {product.price}
                            </div>
                        </div>
                        <h3 class="text-lg font-serif font-bold text-gray-800">{product.name}</h3>
                        <p class="text-sm text-gray-500 mt-1">Disponible en tienda</p>
                    </div>
                ))}
            </div>
        </div>
    </main>
    <Footer />
</Layout>