---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

// 1. Obtener categorías
let categories: CollectionEntry<'categories'>[] = [];
try {
    categories = await getCollection('categories');
    // Ordenar si quieres mantener el orden específico
    const desiredOrder = ['ropa-mujer', 'belleza', 'calzados'];
    categories = categories.sort((a, b) => {
        const indexA = desiredOrder.indexOf(a.id);
        const indexB = desiredOrder.indexOf(b.id);
        return (indexA === -1 ? 99 : indexA) - (indexB === -1 ? 99 : indexB);
    });
} catch (e) {
    console.log("Error cargando categorías");
}
---

<Layout title="Nuestra Colección | Eva Torres">
    <Header />
    <main class="py-16 bg-white min-h-[60vh]">
        <div class="container mx-auto px-4">
            <h1 class="text-5xl font-brand text-center text-eva-green mb-16">Nuestras Colecciones</h1>
            
            {categories.length === 0 ? (
                <div class="text-center py-10">
                    <p class="text-gray-500 mb-4">Aún no hay categorías disponibles.</p>
                    <a href="/" class="text-eva-green font-bold underline">Volver al inicio</a>
                </div>
            ) : (
                <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                    {categories.map((cat) => (
                        <a href={`/coleccion/${cat.id}`} class="group cursor-pointer block">
                            <div class="overflow-hidden rounded-sm shadow-lg mb-4 aspect-[3/4] relative">
                                <img 
                                    src={cat.data.coverImage} 
                                    alt={cat.data.name} 
                                    class="w-full h-full object-cover group-hover:scale-105 transition duration-700"
                                />
                                <div class="absolute inset-0 bg-black/20 group-hover:bg-transparent transition duration-500"></div>
                            </div>
                            <h3 class="text-2xl font-serif text-center text-gray-800 group-hover:text-eva-green transition-colors">
                                {cat.data.name}
                            </h3>
                            {cat.data.description && (
                                <p class="text-center text-gray-500 text-sm mt-2 font-light">
                                    {cat.data.description}
                                </p>
                            )}
                        </a>
                    ))}
                </div>
            )}
        </div>
    </main>
    <Footer />
</Layout>