---
import Icon from './Icons.astro';
---
<div class="bg-eva-dark text-eva-cream text-xs py-2 hidden md:block">
    <div class="container mx-auto px-4 flex justify-between items-center">
        <span>Bda. Francisco de Quevedo, Bloque 22, Local C, Arahal</span>
        <a href="tel:+34651688937" class="hover:text-eva-gold transition">📞 651 688 937</a>
    </div>
</div>

<header class="bg-eva-green text-white shadow-lg sticky top-0 z-40 border-b border-eva-gold/30">
  <div class="container mx-auto px-4 py-3 flex justify-between items-center relative">
    
    <a href="/" class="text-4xl md:text-5xl font-brand hover:text-eva-gold transition-colors transform translate-y-1">
      Eva Torres
    </a>

    <nav class="hidden md:flex items-center gap-8 text-sm uppercase tracking-widest font-medium">
      <a href="/" class="hover:text-eva-gold transition py-2">Inicio</a>
      <a href="/nosotros" class="hover:text-eva-gold transition py-2">Nosotros</a>
      
      <div class="relative group">
        <a href="/coleccion" class="hover:text-eva-gold transition py-2 flex items-center gap-1 cursor-pointer">
            Colección 
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 mt-0.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
            </svg>
        </a>
        
        <div class="absolute left-0 mt-2 w-56 bg-white text-gray-800 shadow-xl rounded-b-lg opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 transform group-hover:translate-y-0 translate-y-2 border-t-4 border-eva-gold">
            <a href="/coleccion/ropa-mujer" class="block px-6 py-3 hover:bg-gray-50 hover:text-eva-green transition border-b border-gray-100">Ropa de Mujer</a>
            <a href="/coleccion/calzados" class="block px-6 py-3 hover:bg-gray-50 hover:text-eva-green transition border-b border-gray-100">Calzados</a>
            <a href="/coleccion/belleza" class="block px-6 py-3 hover:bg-gray-50 hover:text-eva-green transition">Belleza y Accesorios</a>
        </div>
      </div>

      <a href="/contacto" class="hover:text-eva-gold transition py-2">Contacto</a>
    </nav>

    <div class="flex items-center gap-4">
        <a href="https://www.facebook.com/evamaria.rodrigueztorres.9" target="_blank" aria-label="Facebook" class="bg-white/10 p-2 rounded-full hover:bg-eva-gold hover:text-eva-dark transition">
            <Icon name="facebook" class="w-5 h-5" />
        </a>
    </div>
  </div>
</header>